{
  "knowledge_sources": [
    "https://WaveLinks.design/foundations",
    "https://WaveLinks.design/components",
    "https://WaveLinks.design/patterns",
    "https://WaveLinks.design/resources",
    "https://WaveLinks.design/foundations/icons",
    "https://WaveLinks.design/foundations/colour",
    "https://WaveLinks.design/foundations/cards",
    "https://WaveLinks.design/foundations/radius",
    "https://WaveLinks.design/foundations/motion-system",
    "https://transferWaveLinks.github.io/icons"
  ],
  "strict_rules_applied": {
    "icons": {
      "principles": [
        "less_is_more",
        "universally_understood_metaphor",
        "rounded_corners_square_terminals",
        "small_size_clarity"
      ],
      "sizes": {
        "product": [
          16,
          24,
          32
        ],
        "editorial": [
          16,
          24,
          48,
          64,
          96
        ],
        "exports": [
          16,
          24,
          32,
          48,
          64,
          96,
          128,
          256,
          512,
          1024
        ]
      },
      "usage_variants": [
        "flat_interactive",
        "flat_informational",
        "flat_white_badge",
        "3d_green_material",
        "3d_tapestry_material"
      ]
    },
    "colour": {
      "core": {
        "bright_green": "#9FE870",
        "forest_green": "#163300"
      },
      "content": {
        "primary": "#0E0F0C",
        "secondary": "#454745",
        "tertiary": "#6A6C6A"
      },
      "interactive": {
        "primary": "#163300",
        "accent": "#9FE870",
        "secondary": "#868685"
      },
      "background_balance": "white_first_with_neutral_and_controlled_green_pops",
      "secondary_bias_from_refs": {
        "accent_cool": "#4A8F8E",
        "accent_warm": "#836939",
        "accent_hot": "#803859"
      }
    },
    "radius": {
      "mobile": {
        "small": 10,
        "medium": 16,
        "large": 24,
        "x_large": 32
      },
      "desktop": {
        "small": 16,
        "medium": 20,
        "large": 30,
        "x_large": 40,
        "xx_large": 60
      }
    },
    "platform_stack": {
      "layers": [
        "tapestry_base",
        "seamless_translucent_layer",
        "white_label_surface"
      ],
      "rule": "use cropped tapestry details not full-scale single image"
    },
    "motion_direction_for_future_animation": {
      "ratio": {
        "snappy": 0.6,
        "fluid": 0.3,
        "intuitive": 0.1
      },
      "notes": [
        "natural_physical_weight",
        "avoid_disorienting_flash",
        "layered_tapestry_flow"
      ]
    }
  }
}